{
    "name": "phpdot/container-swoole",
    "description": "Swoole context provider for phpdot/container",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "phpdot/container": "^1.0",
        "ext-swoole": ">=5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "swoole/ide-helper": "*",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Container\\Swoole\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Container\\Swoole\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=256M",
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix"
    }
}
